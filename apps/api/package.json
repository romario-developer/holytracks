    "dotenv": "^16.3.1",
    "fastify": "^4.25.0",
    "holytracks": "file:../..",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.13.2",
    "prisma": "5.12.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.4"
  }
